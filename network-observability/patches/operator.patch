diff --git a/Makefile b/Makefile
index 6f2788a9..b4b51d7f 100644
--- a/Makefile
+++ b/Makefile
@@ -405,11 +405,11 @@ uninstall: kustomize ## Uninstall CRDs from the K8s cluster specified in ~/.kube
 
