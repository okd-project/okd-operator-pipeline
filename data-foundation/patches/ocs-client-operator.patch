Subject: [PATCH] OKDify

---
 ...client-operator.clusterserviceversion.yaml | 22 +++++++++----------
 1 file changed, 11 insertions(+), 11 deletions(-)

diff --git a/config/manifests/bases/ocs-client-operator.clusterserviceversion.yaml b/config/manifests/bases/ocs-client-operator.clusterserviceversion.yaml
index 060f8319..2c4d9b58 100644
--- a/config/manifests/bases/ocs-client-operator.clusterserviceversion.yaml
+++ b/config/manifests/bases/ocs-client-operator.clusterserviceversion.yaml
@@ -7,13 +7,13 @@ metadata:
     categories: Storage
     console.openshift.io/plugins: '["odf-client-console"]'
     containerImage: quay.io/ocs-dev/ocs-client-operator:latest
-    description: OpenShift Data Foundation client operator enables consumption of
-      storage services from a remote centralized OpenShift Data Foundation provider
+    description: OKD Data Foundation client operator enables consumption of
+      storage services from a remote centralized OKD Data Foundation provider
       cluster.
     operatorframework.io/suggested-namespace: openshift-storage
     operators.operatorframework.io/operator-type: standalone
     repository: https://github.com/red-hat-storage/ocs-client-operator
-    support: Red Hat
+    support: OKD Community
   labels:
     operatorframework.io/arch.amd64: supported
     operatorframework.io/arch.ppc64le: supported
@@ -29,12 +29,12 @@ spec:
       kind: StorageClient
       name: storageclients.ocs.openshift.io
       version: v1alpha1
-  description: OpenShift Data Foundation client operator enables consumption of storage
-    services from a remote centralized OpenShift Data Foundation provider cluster.
-  displayName: OpenShift Data Foundation Client
+  description: OKD Data Foundation client operator enables consumption of storage
+    services from a remote centralized OKD Data Foundation provider cluster.
+  displayName: OKD Data Foundation Client
   icon:
-  - base64data: 
-    mediatype: image/svg+xml
+  - base64data: 
+    mediatype: image/png
   install:
     spec:
       deployments: null
@@ -56,9 +56,9 @@ spec:
   - name: OCS Client Operator
     url: https://github.com/red-hat-storage/ocs-client-operator
   maintainers:
-  - email: ocs-support@redhat.com
-    name: Red Hat
+  - email: maintainers@okd.io
+    name: OKD Community
   maturity: alpha
   provider:
-    name: Red Hat
+    name: OKD Community
   version: 0.0.0
