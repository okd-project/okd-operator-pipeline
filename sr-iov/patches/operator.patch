From 23b15dd690844d1947552df0f965aad10f473b09 Mon Sep 17 00:00:00 2001
From: Owen Howard <owen@ziax.com>
Date: Sat, 10 May 2025 14:45:56 +0100
Subject: [PATCH] OKDify

---
 .../sriov-network-operator.clusterserviceversion.yaml  | 10 +++++-----
 1 file changed, 5 insertions(+), 5 deletions(-)

diff --git a/config/manifests/bases/sriov-network-operator.clusterserviceversion.yaml b/config/manifests/bases/sriov-network-operator.clusterserviceversion.yaml
index 416329c64..ddc9bdfe4 100644
--- a/config/manifests/bases/sriov-network-operator.clusterserviceversion.yaml
+++ b/config/manifests/bases/sriov-network-operator.clusterserviceversion.yaml
@@ -9,7 +9,7 @@ metadata:
     containerImage: quay.io/openshift/origin-sriov-network-operator:4.18
     createdAt: 2019/04/30
     description: An operator for configuring SR-IOV components and initializing SRIOV
-      network devices in Openshift cluster.
+      network devices in an OKD cluster.
     features.operators.openshift.io/cnf: "false"
     features.operators.openshift.io/cni: "true"
     features.operators.openshift.io/csi: "false"
@@ -51,7 +51,7 @@ metadata:
       }
     operators.operatorframework.io/internal-objects: '["sriovnetworknodestates.sriovnetwork.openshift.io"]'
     repository: https://github.com/k8snetworkplumbingwg/sriov-network-operator
-    support: Red Hat
+    support: OKD Community
     target.workload.openshift.io/management: '{"effect": "PreferredDuringScheduling"}'
   labels:
     operatorframework.io/arch.amd64: supported
@@ -97,10 +97,10 @@ spec:
       name: sriovoperatorconfigs.sriovnetwork.openshift.io
       version: v1
   description: |
-    # SR-IOV Network Operator for Openshift
+    # SR-IOV Network Operator for OKD
 
     ## Introduction
-    The sriov-network-operator is generally responsible for configuring the sriov components in a openshift cluster.
+    The sriov-network-operator is generally responsible for configuring the sriov components in an OKD cluster.
 
     ### Supported Features
     * Initialize the SR-IOV NICs on nodes.
@@ -156,5 +156,5 @@ spec:
   - email: support@redhat.com
     name: Red Hat
   provider:
-    name: Red Hat
+    name: OKD Community
   version: 4.18.0
-- 
2.50.1

