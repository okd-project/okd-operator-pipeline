From 42030d8a723bc9ea7bd5b0712775ddd28b4b988e Mon Sep 17 00:00:00 2001
From: Owen Howard <owen@ziax.com>
Date: Tue, 12 May 2026 10:43:40 +0100
Subject: [PATCH] OKDify

---
 Makefile                                                    | 2 +-
 .../bases/metallb-operator.clusterserviceversion.yaml       | 6 +++---
 manifests/ocpcsv/webhookservicecainjection_patch.yaml       | 2 +-
 3 files changed, 5 insertions(+), 5 deletions(-)

diff --git a/Makefile b/Makefile
index 27c4aecf..0ea1afda 100755
--- a/Makefile
+++ b/Makefile
@@ -155,7 +155,7 @@ bundle: operator-sdk manifests  ## Generate bundle manifests and metadata, then
 	rm bundle/manifests/metallb.io_servicel2statuses.yaml # TODO remove when metallb support is added
 	$(OPERATOR_SDK) generate kustomize manifests --interactive=false -q
 	cd config/manager && $(KUSTOMIZE) edit set image controller=$(IMG)
-	$(KUSTOMIZE) build config/manifests | $(OPERATOR_SDK) generate bundle -q --overwrite --version $(CSV_VERSION) $(BUNDLE_METADATA_OPTS) --extra-service-accounts "controller,speaker,frr-k8s-daemon"
+	$(KUSTOMIZE) build $(KUSTOMIZE_DEPLOY_DIR) | $(OPERATOR_SDK) generate bundle -q --overwrite --version $(CSV_VERSION) $(BUNDLE_METADATA_OPTS) --extra-service-accounts "controller,speaker,frr-k8s-daemon"
 	$(OPERATOR_SDK) bundle validate ./bundle
 
 bundle-release: kustomize bundle bump_versions  ## Generate the bundle manifests for a PR
diff --git a/manifests/ocpcsv/bases/metallb-operator.clusterserviceversion.yaml b/manifests/ocpcsv/bases/metallb-operator.clusterserviceversion.yaml
index fb952d68..93273af8 100644
--- a/manifests/ocpcsv/bases/metallb-operator.clusterserviceversion.yaml
+++ b/manifests/ocpcsv/bases/metallb-operator.clusterserviceversion.yaml
@@ -8,13 +8,13 @@ metadata:
     containerImage: quay.io/openshift/origin-metallb-operator:4.20
     createdAt: "2021-06-28 00:00:00"
     olm.skipRange: ">=4.8.0 <4.20.0"
-    description: An operator for deploying MetalLB on a kubernetes cluster.
+    description: An operator for deploying MetalLB on an OKD cluster.
     operators.operatorframework.io/builder: operator-sdk-v1.8.0+git
     operators.operatorframework.io/project_layout: go.kubebuilder.io/v2
     operatorframework.io/suggested-namespace: metallb-system
     operators.openshift.io/infrastructure-features: '["disconnected"]'
     repository: https://github.com/openshift/metallb-operator
-    support: Red Hat
+    support: OKD Community
   labels:
     operatorframework.io/arch.amd64: supported
     operatorframework.io/arch.s390x: supported
@@ -58,7 +58,7 @@ spec:
     name: Russell Bryant
   maturity: alpha
   provider:
-    name: Community
+    name: OKD Community
   version: 4.20.0
   labels:
     olm-owner-enterprise-app: metallb-operator
diff --git a/manifests/ocpcsv/webhookservicecainjection_patch.yaml b/manifests/ocpcsv/webhookservicecainjection_patch.yaml
index a29e74a8..2b9b5350 100644
--- a/manifests/ocpcsv/webhookservicecainjection_patch.yaml
+++ b/manifests/ocpcsv/webhookservicecainjection_patch.yaml
@@ -2,7 +2,7 @@
 apiVersion: v1
 kind: Service
 metadata:
-  name: webhook-service
+  name: metallb-operator-webhook-service
   namespace: system
   annotations:
     service.alpha.openshift.io/serving-cert-secret-name: metallb-operator-webhook-server-service-cert
