From 48f7278f7532c1572d7a127694cd41afd0cec6bf Mon Sep 17 00:00:00 2001
From: Owen Howard <owen@ziax.com>
Date: Sun, 5 Oct 2025 16:18:22 +0100
Subject: [PATCH] OKDify

---
 config/manifests/kustomization.yaml |  6 +++++
 config/manifests/okd/patch.yaml     | 38 +++++++++++++++++++++++++++++
 2 files changed, 44 insertions(+)
 create mode 100644 config/manifests/okd/patch.yaml

diff --git a/config/manifests/kustomization.yaml b/config/manifests/kustomization.yaml
index f7fdf63e..bee5dd65 100644
--- a/config/manifests/kustomization.yaml
+++ b/config/manifests/kustomization.yaml
@@ -26,3 +26,9 @@ resources:
 #    # Update the indices in this path if adding or removing volumes in the manager's Deployment.
 #    - op: remove
 #      path: /spec/template/spec/volumes/0
+
+
+patches:
+  - target:
+      kind: ClusterServiceVersion
+    path: okd/patch.yaml
\ No newline at end of file
diff --git a/config/manifests/okd/patch.yaml b/config/manifests/okd/patch.yaml
new file mode 100644
index 00000000..f089be72
--- /dev/null
+++ b/config/manifests/okd/patch.yaml
@@ -0,0 +1,38 @@
+- op: replace
+  path: /metadata/annotations/operator.openshift.io~1uninstall-message
+  value: The external secrets operator for OKD
+    will be removed from external-secrets-operator namespace. If your Operator 
+    configured any off-cluster resources, these will continue to run and require
+    manual cleanup. All operands created by the operator will need to be manually
+    cleaned up. Please refer to https://docs.openshift.com/container-platform/latest/security/external_secrets_operator/external-secrets-operator-uninstall.html
+    for additional steps.
+- op: replace
+  path: /metadata/annotations/support
+  value: OKD Community
+- op: remove
+  path: /metadata/annotations/operators.openshift.io~1valid-subscription
+- op: replace
+  path: /spec/description
+  value: External Secrets Operator for OKD deploys and manages `external-secrets`
+    application in OKD clusters. `external-secrets` provides an uniformed interface to
+    fetch secrets stored in external providers like AWS Secrets Manager,
+    HashiCorp Vault, Google Secrets Manager, Azure Key Vault, IBM Cloud Secrets Manager
+    to name a few, stores them as secrets in OKD. It provides APIs to define
+    authentication and the details of the secret to fetch.
+- op: replace
+  path: /spec/displayName
+  value: External Secrets Operator for OKD
+- op: replace
+  path: /spec/icon
+  value:
+    - base64data: 
+      mediatype: image/png
+- op: replace
+  path: /spec/maintainers
+  value:
+    - email: maintainers@okd.io
+      name: OKD Community
+- op: replace
+  path: /spec/provider
+  value:
+      name: OKD Community
\ No newline at end of file
-- 
2.51.0

