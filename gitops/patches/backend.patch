From 7bb427791a93afa577cc466b76fb7de9d43cf27d Mon Sep 17 00:00:00 2001
From: Owen Howard <owen@ziax.com>
Date: Wed, 4 Jun 2025 13:33:58 +0100
Subject: [PATCH] OKDify

---
 .konflux/Containerfile.plugin | 22 ++++++++++++++++++++++
 1 file changed, 22 insertions(+)
 create mode 100644 .konflux/Containerfile.plugin

diff --git a/.konflux/Containerfile.plugin b/.konflux/Containerfile.plugin
new file mode 100644
index 0000000..c7b9dd1
--- /dev/null
+++ b/.konflux/Containerfile.plugin
@@ -0,0 +1,22 @@
+# Build Stage
+FROM  registry.access.redhat.com/ubi9/go-toolset:1.23 AS builder
+ARG GIT_COMMIT
+
+COPY --chown=default . .
+
+RUN CGO_ENABLED=0 GOOS=linux go build -a -mod=readonly \
+  -ldflags "-X github.com/redhat-developer/gitops-backend/pkg/health.GitRevision=${GIT_COMMIT}" ./cmd/backend-http
+
+# Final Stage
+FROM quay.io/centos/centos:stream9-minimal
+WORKDIR /
+COPY --from=builder /opt/app-root/src/backend-http .
+EXPOSE 8080
+ENTRYPOINT ["./backend-http"]
+
+LABEL \
+    License="Apache 2.0" \
+    summary="OKD GitOps Backend Service" \
+    io.k8s.display-name="OKD GitOps Backend Service" \
+    maintainer="OKD Community <maintainers@okd.io>" \
+    description="OKD GitOps Backend Service"
\ No newline at end of file
