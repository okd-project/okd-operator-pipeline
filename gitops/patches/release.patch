diff --git a/clis/argocd-agentctl/Dockerfile b/clis/argocd-agentctl/Dockerfile
index 3d0a5bb..e2f71a1 100644
--- a/clis/argocd-agentctl/Dockerfile
+++ b/clis/argocd-agentctl/Dockerfile
@@ -17,14 +17,14 @@
 ####################################################################################################
 # Argo CD Agentctl Build stage which performs the actual build of Argocd-agentctl binaries
 ####################################################################################################
-FROM registry.redhat.io/rhel8/go-toolset:1.25 AS builder
+FROM registry.access.redhat.com/ubi9/go-toolset:1.24 AS builder
 
 USER root
 
 COPY sources/argocd-agent /src/argocd-agentctl
 WORKDIR /src/argocd-agentctl
 
-ENV GOFLAGS="-mod=mod" 
+ENV GOFLAGS="-mod=mod"
 
 RUN go mod download
 RUN make cli-all
@@ -40,7 +40,7 @@ RUN cd dist && \
 ####################################################################################################
 # Package the binaries into the image using UBI (Universal Base Image)
 ####################################################################################################
-FROM registry.access.redhat.com/ubi8/ubi
+FROM registry.access.redhat.com/ubi9/ubi
 
 # This directory is checked by the ecosystem-cert-preflight-checks task in Konflux
 COPY LICENSE /licenses/
