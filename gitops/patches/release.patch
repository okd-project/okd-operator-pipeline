index 7eec483..6d4fd9b 100644
--- a/clis/argocd/Dockerfile
+++ b/clis/argocd/Dockerfile
@@ -17,7 +17,7 @@
 ####################################################################################################
 # Builder stage which performs the build of Argocd-cli binaries
 ####################################################################################################
-FROM registry.redhat.io/rhel8/go-toolset:1.25 AS builder
+FROM registry.access.redhat.com/ubi9/go-toolset:1.24 AS builder
 
 USER root
 
@@ -31,7 +31,7 @@ ARG CI_VERSION
