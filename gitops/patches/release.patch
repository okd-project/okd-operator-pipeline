 #
 # ------------------------------------------------------------------------
 
-FROM brew.registry.redhat.io/rh-osbs/openshift-golang-builder:rhel_8_1.24  AS builder
+FROM registry.access.redhat.com/ubi9/go-toolset:1.24  AS builder
