 Dockerfile                                    |    9 +-
 .../bases/nfd.clusterserviceversion.yaml      | 1515 ++++++++---------
 2 files changed, 717 insertions(+), 807 deletions(-)

diff --git a/Dockerfile b/Dockerfile
index 137aa947..f5d0caeb 100644
--- a/Dockerfile
+++ b/Dockerfile
@@ -1,16 +1,15 @@
 # Build the manager binary
-FROM registry.ci.openshift.org/ocp/builder:rhel-9-golang-1.22-openshift-4.18 AS builder
-WORKDIR /go/src/github.com/openshift/cluster-nfd-operator
+FROM registry.access.redhat.com/ubi9/go-toolset:1.22 AS builder
 
 # Build
-COPY . .
+COPY --chown=default . .
 RUN make build
 
 # Create production image for running the operator
-FROM registry.ci.openshift.org/ocp/4.18:base-rhel9
+FROM quay.io/centos/centos:stream9
 
 ARG CSV=4.18
-COPY --from=builder /go/src/github.com/openshift/cluster-nfd-operator/node-feature-discovery-operator /
+COPY --from=builder /opt/app-root/src/node-feature-discovery-operator /
 
 COPY manifests /manifests
 
diff --git a/config/manifests/bases/nfd.clusterserviceversion.yaml b/config/manifests/bases/nfd.clusterserviceversion.yaml
index c9b830cf..39c6cd88 100644
