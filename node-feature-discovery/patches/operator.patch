From b688b0c222218d8e7f46c2342a85953b0f255f08 Mon Sep 17 00:00:00 2001
From: Owen Howard <owen@ziax.com>
Date: Thu, 5 Jun 2025 16:45:02 +0100
Subject: [PATCH] OKDify

---
 Dockerfile                                          | 11 ++++++-----
 .../manifests/bases/nfd.clusterserviceversion.yaml  | 13 ++++++-------
 2 files changed, 12 insertions(+), 12 deletions(-)

diff --git a/Dockerfile b/Dockerfile
index fee7377d..f49ab6df 100644
--- a/Dockerfile
+++ b/Dockerfile
@@ -1,16 +1,17 @@
 # Build the manager binary
-FROM registry.ci.openshift.org/ocp/builder:rhel-9-golang-1.24-openshift-4.21 AS builder
-WORKDIR /go/src/github.com/openshift/cluster-nfd-operator
+ARG OKD_SHORT
+
+FROM registry.access.redhat.com/ubi9/go-toolset:1.24 AS builder
 
 # Build
-COPY . .
+COPY --chown=default . .
 RUN make build
 
 # Create production image for running the operator
-FROM registry.ci.openshift.org/ocp/4.21:base-rhel9
+FROM registry.ci.openshift.org/origin/scos-${OKD_SHORT}:base-stream9
 
 ARG CSV=4.20
-COPY --from=builder /go/src/github.com/openshift/cluster-nfd-operator/node-feature-discovery-operator /
+COPY --from=builder /opt/app-root/src/node-feature-discovery-operator /
 
 COPY manifests /manifests
 
diff --git a/config/manifests/bases/nfd.clusterserviceversion.yaml b/config/manifests/bases/nfd.clusterserviceversion.yaml
index 84d2758b..276a8d33 100644
--- a/config/manifests/bases/nfd.clusterserviceversion.yaml
+++ b/config/manifests/bases/nfd.clusterserviceversion.yaml
@@ -64,9 +64,8 @@ metadata:
         }
       ]
     capabilities: Deep Insights
-    categories: Integration & Delivery,OpenShift Optional
+    categories: Integration & Delivery,OKD Optional
     containerImage: quay.io/openshift/origin-cluster-nfd-operator:4.20
-    createdAt: "2025-04-08T11:06:30Z"
     description: |-
       The Node Feature Discovery Operator manages the detection of hardware features and configuration in a Kubernetes cluster by labeling the nodes with hardware-specific information. The Node Feature Discovery (NFD) will label the host with node-specific attributes, like PCI cards, kernel, or OS version, and many more.
 
@@ -99,9 +98,9 @@ metadata:
     operators.operatorframework.io/builder: operator-sdk-v1.32.0
     operators.operatorframework.io/internal-objects: '["noderesourcetopologies.topology.node.k8s.io"]'
     operators.operatorframework.io/project_layout: go.kubebuilder.io/v3
-    provider: Red Hat
+    provider: OKD Community
     repository: https://github.com/openshift/cluster-nfd-operator
-    support: Red Hat
+    support: OKD Community
   labels:
     operatorframework.io/arch.amd64: supported
     operatorframework.io/arch.arm64: supported
@@ -829,11 +828,11 @@ spec:
   - name: Node Feature Discovery Documentation
     url: https://kubernetes-sigs.github.io/node-feature-discovery/stable/get-started/index.html
   maintainers:
-  - email: support@redhat.com
-    name: Red Hat Support
+    - email: maintainers@okd.io
+      name: OKD Community
   maturity: stable
   minKubeVersion: 1.22.0
   provider:
-    name: Red Hat
+    name: OKD Community
     url: https://github.com/openshift/cluster-nfd-operator
   version: 4.20.0
-- 
