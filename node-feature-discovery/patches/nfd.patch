From ee95b79c85938ca41ca8cacb739bd85e3af08bb7 Mon Sep 17 00:00:00 2001
From: Owen Howard <owen@ziax.com>
Date: Thu, 5 Jun 2025 16:46:17 +0100
Subject: [PATCH] OKDify

---
 Dockerfile | 13 ++++++-------
 1 file changed, 6 insertions(+), 7 deletions(-)

diff --git a/Dockerfile b/Dockerfile
index 79edcbe81..02b4a9d9a 100644
--- a/Dockerfile
+++ b/Dockerfile
@@ -1,19 +1,18 @@
 # Build node feature discovery
-FROM registry.ci.openshift.org/ocp/builder:rhel-9-golang-1.22-openshift-4.18 AS builder
+FROM registry.access.redhat.com/ubi9/go-toolset:1.22 AS builder
 
-WORKDIR /go/node-feature-discovery
-COPY . .
+COPY --chown=default . .
 
 # Do actual build
 ARG VERSION=v0.10.0
 ARG HOSTMOUNT_PREFIX=/host-
-RUN make install VERSION=${VERSION} HOSTMOUNT_PREFIX=${HOSTMOUNT_PREFIX}
+RUN make build VERSION=${VERSION} HOSTMOUNT_PREFIX=${HOSTMOUNT_PREFIX}
 
 # Create full variant of the production image
-FROM registry.ci.openshift.org/ocp/4.18:base-rhel9
+FROM quay.io/centos/centos:stream9
 
 # Use more verbose logging of gRPC
 ENV GRPC_GO_LOG_SEVERITY_LEVEL="INFO"
 
-COPY --from=builder /go/node-feature-discovery/deployment/components/worker-config/nfd-worker.conf.example /etc/kubernetes/node-feature-discovery/nfd-worker.conf
-COPY --from=builder /go/bin/* /usr/bin/
+COPY --from=builder /opt/app-root/src/deployment/components/worker-config/nfd-worker.conf.example /etc/kubernetes/node-feature-discovery/nfd-worker.conf
+COPY --from=builder /opt/app-root/src/bin/* /usr/bin/
-- 
